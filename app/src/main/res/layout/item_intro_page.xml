<?xml version="1.0" encoding="utf-8"?>
<!-- 🎨 영자 수석 디자이너 - 시안 구조 그대로: 상단 히어로 이미지 + 하단 텍스트 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_intro_premium_dark">

    <!-- ═══════════════════════════════════════ -->
    <!-- 🖼️ 상단: 히어로 이미지 영역 (카드 높이의 55%) -->
    <!-- ═══════════════════════════════════════ -->
    <ImageView
        android:id="@+id/iv_icon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/intro_hero_memory"
        android:scaleType="centerCrop"
        android:contentDescription="intro image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/divider_gradient"
        app:layout_constraintHeight_percent="0.55" />

    <!-- 이미지 하단에 어두운 그라데이션 페이드아웃 -->
    <View
        android:id="@+id/divider_gradient"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_intro_premium_dark"
        android:alpha="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/view_gold_divider" />

    <!-- 🥂 Gold Divider -->
    <View
        android:id="@+id/view_gold_divider"
        android:layout_width="36dp"
        android:layout_height="1dp"
        android:background="#C9A96E"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_tagline" />

    <!-- ═══════════════════════════════════════ -->
    <!-- 📝 하단: 텍스트 영역 -->
    <!-- ═══════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_tagline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="14dp"
        android:text="둘만의 소중한 데이트 기록"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:letterSpacing="0.02"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_sub_tagline" />

    <TextView
        android:id="@+id/tv_sub_tagline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="28dp"
        android:text="우리가 함께한 예쁜 순간들을&#10;나만의 다이어리에 담아보세요"
        android:textColor="#909090"
        android:textSize="14sp"
        android:letterSpacing="0.01"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
