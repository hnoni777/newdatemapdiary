<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">


    <!-- 🧭 [상단 경로 정보 패널] 카카오맵 스타일 -->
    <LinearLayout
        android:id="@+id/panel_directions_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#4D7CFF"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 이동 경로 박스 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#66000000"
                android:padding="4dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="#1AFFFFFF">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="출발"
                        android:textColor="#FFD700"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/text_start_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="현재 위치"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/kyobo_hand_family" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22FFFFFF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="#1AFFFFFF">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="도착"
                        android:textColor="#FF4D4D"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/text_directions_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="목적지 주소"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/kyobo_hand_family" />
                </LinearLayout>
            </LinearLayout>

            <!-- (아이콘 제거됨) -->
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/directions_map_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/panel_directions_top"
        app:layout_constraintBottom_toTopOf="@id/card_directions_bottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btn_directions_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:src="@drawable/ic_arrow_back"
        android:background="@drawable/bg_gold_pill_button"
        android:backgroundTint="#CC000000"
        android:padding="10dp"
        android:scaleType="fitCenter"
        app:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:elevation="20dp" />

    <!-- 🌟 [코다리 명품 내비 카드장치] 골드 옐로우 시그니처 테마 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_directions_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#FFD700"
        app:cardElevation="12dp"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btn_launch_kakao_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/text_directions_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="소요시간: --분"
                    android:textColor="#000000"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_directions_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이동거리: --km"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- 🚗 카카오맵 실행 블랙 버튼 (크기 축소) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_gold_pill_button"
                android:backgroundTint="#000000"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:gravity="center">
                
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_white_location"
                    app:tint="#FFD700"
                    android:layout_marginEnd="4dp"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="안내 시작"
                    android:textColor="#FFD700"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
